APP_NAME=ConfirmaID
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8088
APP_PORT=8088

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=confirma_id
DB_USERNAME=confirma_id
DB_PASSWORD=confirma_id
DB_FORWARD_PORT=15432

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_FORWARD_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="nao-responda@confirmaid.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_FORWARD_PORT=8025

AWS_ACCESS_KEY_ID=confirmaid
AWS_SECRET_ACCESS_KEY=confirmaid-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=confirma-id
AWS_URL=http://localhost:9000/confirma-id
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_VISIBILITY=private
FILESYSTEM_THROW=true

MINIO_ROOT_USER=confirmaid
MINIO_ROOT_PASSWORD=confirmaid-secret
MINIO_FORWARD_PORT=9000
MINIO_CONSOLE_FORWARD_PORT=9001

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173

CONFIRMAID_UPLOAD_MAX_FILE_KB=5120
CONFIRMAID_PARTNER_API_RATE_PER_MINUTE=60
CONFIRMAID_PARTNER_WEB_RATE_PER_MINUTE=30

BACKUP_DATABASE_ENABLED=false
BACKUP_DATABASE_RETENTION_DAYS=30
BACKUP_STORAGE_ENABLED=false
BACKUP_STORAGE_RETENTION_DAYS=30
